{
  "//": "Heuristics format: outer keys are file/dir markers that identify project type. Unlike .projections.json, this is NOT a flat glob-to-options mapping.",

  "Gemfile&test/": {
    "app/*.rb": { "alternate": "test/{}_test.rb" },
    "lib/*.rb": { "alternate": "test/{}_test.rb" },
    "test/*_test.rb": { "alternate": ["app/{}.rb", "lib/{}.rb"] }
  },

  "Gemfile&spec/": {
    "app/*.rb": { "alternate": "spec/{}_spec.rb" },
    "lib/*.rb": { "alternate": "spec/{}_spec.rb" },
    "spec/*_spec.rb": { "alternate": ["app/{}.rb", "lib/{}.rb"] }
  },

  "py/pyproject.toml": {
    "py/src/*.py": { "alternate": ["py/tests/{}_test.py", "py/tests/test_{}.py"] },
    "py/tests/*_test.py": { "alternate": "py/src/{}.py" },
    "py/tests/test_*.py": { "alternate": "py/src/{}.py" }
  }
}
