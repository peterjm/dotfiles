#!/bin/bash

# Lists worktrees under $(git-wt-base) with name, branch, dirty/clean, merged/unmerged.

WT_BASE=$(git-wt-base)

if [ ! -d "$WT_BASE" ]; then
  exit 0
fi

shopt -s nullglob
for wt in "$WT_BASE"/*/; do
  wt="${wt%/}"
  name=$(basename "$wt")
  branch=$(git -C "$wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")

  if [ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]; then
    dirty="dirty"
  else
    dirty="clean"
  fi

  if git-branch-merged "$branch" 2>/dev/null; then
    merged="merged"
  else
    merged="unmerged"
  fi

  printf "%-20s %-30s %-7s %s\n" "$name" "$branch" "$dirty" "$merged"
done
