#!/bin/bash

function has_arg () {
  local search=$1
  shift
  for arg in "$@"; do
    if [ "$arg" == "$search" ]; then
      return 0
    fi
  done

  return 1
}

if git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
  diff_filter=()
  if has_arg "--no-deleted" "$@"; then
    diff_filter=(--diff-filter=d)
  fi

  if has_arg "-b" "$@" || has_arg "--include-branch-commits" "$@"; then
    git diff --name-only "${diff_filter[@]}" $(git merge-base HEAD $(git-main-branch))
    git ls-files -o --exclude-standard
  else
    git diff --name-only "${diff_filter[@]}"
    git ls-files -o --exclude-standard
  fi
else
  exit 1
fi
