#!/bin/bash

# Removes worktrees under $(git-wt-base) whose branches have been merged into
# main, and deletes those branches.

set -e

WT_BASE=$(git-wt-base)

if [ ! -d "$WT_BASE" ]; then
  exit 0
fi

shopt -s nullglob
for wt in "$WT_BASE"/*/; do
  wt="${wt%/}"
  name=$(basename "$wt")
  branch=$(git -C "$wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

  if [ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]; then
    echo "Skipping '$name' (dirty)"
    continue
  fi

  if [ -z "$branch" ] || ! git show-ref --verify --quiet "refs/heads/$branch"; then
    echo "Skipping '$name' (no local branch)"
    continue
  fi

  if ! git-branch-merged "$branch"; then
    echo "Skipping '$name' (branch '$branch' not merged)"
    continue
  fi

  if ! git worktree remove "$wt" 2>/dev/null; then
    echo "Skipping '$name' (remove failed)"
    continue
  fi

  git branch -d "$branch"
  echo "Removed '$name' (branch '$branch' deleted)"
done

git worktree prune
