[
  {
    "src": "app/(.*).rb",
    "dest": "test/$1_test.rb"
  },
  {
    "src": "test/(.*)_test.rb",
    "dest": "app/$1.rb"
  },
  {
    "src": "app/(.*).rb",
    "dest": "spec/$1_spec.rb"
  },
  {
    "src": "spec/(.*)_spec.rb",
    "dest": "app/$1.rb"
  },
  {
    "src": "src/(.*)/(.*).py",
    "dest": "src/$1/tests/$2_test.py"
  },
  {
    "src": "src/(.*)/(.*).py",
    "dest": "src/$1/tests/test_$2.py"
  },
  {
    "src": "src/(.*)/tests/(.*)_test.py",
    "dest": "src/$1/$2.py"
  },
  {
    "src": "src/(.*)/tests/test_(.*).py",
    "dest": "src/$1/$2.py"
  }
]
